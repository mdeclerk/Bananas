{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Bananas: Init Docker Container",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/init.sh",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Bananas: Build (Release)",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/build.sh",
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Bananas: Build (Debug)",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/build.sh DEBUG=1",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Bananas: Clean",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/clean.sh",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Bananas: Build PyBananas Wheel",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/build-wheel.sh",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Bananas: Play",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/play.sh",
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Bananas: Build (Release) & Play",
      "dependsOrder": "sequence",
      "dependsOn": ["Bananas: Build (Release)", "Bananas: Play"],
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Bananas: Build (Debug) & Play",
      "dependsOrder": "sequence",
      "dependsOn": ["Bananas: Build (Debug)", "Bananas: Play"],
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "PyBananas: Build Wheel",
      "type": "shell",
      "command": "pixi run build-wheel",
      "options": { "cwd": "${workspaceFolder}/PyBananas" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "PyBananas: Play",
      "type": "shell",
      "command": "pixi run play",
      "options": { "cwd": "${workspaceFolder}/PyBananas" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "PyBananas: Test",
      "type": "shell",
      "command": "pixi run test",
      "options": { "cwd": "${workspaceFolder}/PyBananas" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    }
  ]
}
